{
  "name": "wetpaint-compatibility-playwright",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright compatibility and RWD test suite for the WETPAINT SIT environment.",
  "scripts": {
    "test": "playwright test",
    "env:check": "node scripts/check-env-contract.mjs",
    "env:check:strict": "node scripts/check-env-contract.mjs --strict",
    "test:smoke": "playwright test --project=desktop-chrome --project=android-chrome --grep @smoke",
    "test:smoke:full": "playwright test --project=desktop-chrome --project=iphone-safari --project=android-chrome --project=ipad-safari --project=ipad-chrome --grep @smoke",
    "test:smoke:all-projects": "playwright test --grep @smoke",
    "test:compat": "playwright test --grep @compat",
    "test:compat:readonly": "playwright test --grep @readonly",
    "test:compat:stateful": "playwright test --grep @stateful",
    "test:baseline": "node scripts/run-playwright-baseline.mjs",
    "test:baseline:report": "node scripts/run-playwright-baseline.mjs --summary",
    "test:frontdesk": "playwright test --grep @frontdesk",
    "test:frontdesk:readonly": "playwright test --grep \"(?=.*@frontdesk)(?=.*@readonly)\"",
    "test:admin": "playwright test --grep @admin",
    "test:admin:readonly": "playwright test --grep \"(?=.*@admin)(?=.*@readonly)\"",
    "test:shared": "playwright test --grep @shared",
    "test:workflow": "playwright test --grep @workflow",
    "test:ui": "playwright test --grep @ui",
    "test:rwd": "playwright test --grep @rwd",
    "test:media": "playwright test --grep @media",
    "test:mobile": "playwright test --grep @mobile",
    "test:mobile:ios": "playwright test --project=iphone-safari --grep @mobile",
    "test:mobile:ios16plus": "playwright test --project=iphone-safari --grep @mobile",
    "test:mobile:android": "playwright test --project=android-chrome --grep @mobile",
    "test:mobile:all": "playwright test --project=iphone-safari --project=android-chrome --grep @mobile",
    "test:tablet:ipad16plus": "playwright test --project=ipad-safari --project=ipad-chrome",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "record:iphone": "node scripts/playwright-record.mjs iphone",
    "record:ios16plus": "node scripts/playwright-record.mjs ios16plus",
    "record:android": "node scripts/playwright-record.mjs android",
    "record:ipad": "node scripts/playwright-record.mjs ipad-safari",
    "record:ipad16plus": "node scripts/playwright-record.mjs ipad16plus",
    "record:random-mobile": "node scripts/playwright-record.mjs random-mobile",
    "manual:trace": "node scripts/manual-trace-session.mjs random-mobile",
    "manual:trace:iphone": "node scripts/manual-trace-session.mjs iphone",
    "manual:trace:ios16plus": "node scripts/manual-trace-session.mjs ios16plus",
    "manual:trace:android": "node scripts/manual-trace-session.mjs android",
    "manual:trace:ipad": "node scripts/manual-trace-session.mjs ipad-safari",
    "manual:trace:ipad16plus": "node scripts/manual-trace-session.mjs ipad16plus",
    "report:assert-signal": "node scripts/assert-playwright-signal.mjs",
    "report:summary": "node scripts/summarize-playwright-report.mjs",
    "pw:install": "playwright install chromium webkit"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.6.0",
    "dotenv": "^16.6.1",
    "playwright": "^1.55.0",
    "typescript": "^5.9.3"
  }
}
